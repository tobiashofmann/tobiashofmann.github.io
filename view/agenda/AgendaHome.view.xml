<mvc:View
   controllerName="abapconf.web.abapconf.controller.agenda.Agenda"
   displayBlock="true"
   xmlns="sap.m"
   xmlns:l="sap.ui.layout"
   xmlns:tnt="sap.tnt"
   xmlns:core="sap.ui.core"
   xmlns:html="http://www.w3.org/1999/xhtml"
   xmlns:mvc="sap.ui.core.mvc">
   
            

    <!-- H1 -->
    <l:Grid
        containerQuery="false"
        defaultSpan="XL2 L2 M12 S12"
        hSpacing="1">
        <html:div class="exampleDiv"/>
        <HBox height="100px" alignItems="Center" justifyContent="Center">
            <Title level="H1" titleStyle="H1" text="{i18n>agendaH1}"> </Title>
            <layoutData>
                <l:GridData span="XL8 L8 M12 S12"/>
            </layoutData>
        </HBox>
        <html:div class="exampleDiv"/>
    </l:Grid>

    <FlexBox
        height="20px"
        alignItems="Center"
        justifyContent="Center"
        class="sapUiLargeMarginBottom">
        <html:div class="seperator"></html:div>
    </FlexBox>

    <l:Grid
        containerQuery="false"
        defaultSpan="XL2 L2 M12 S12"
        hSpacing="1">
        <html:div class="exampleDiv"/>
        <HBox alignItems="Center" justifyContent="Start">
            <Text width="100%" text="{i18n>agendaP2}" textAlign="Begin"  class="textReadability"></Text>
            <layoutData>
                <l:GridData span="XL8 L8 M12 S12"/>
            </layoutData>
        </HBox>
        <html:div class="exampleDiv"/>
    </l:Grid>

    <l:Grid
        containerQuery="false"
        defaultSpan="XL2 L2 M12 S12"
        hSpacing="1">
        <html:div class="exampleDiv"/>
        <HBox alignItems="Center" justifyContent="Start">
            <Text width="100%" text="{i18n>agendaP3}" textAlign="Begin"  class="textReadability"></Text>
            <layoutData>
                <l:GridData span="XL8 L8 M12 S12"/>
            </layoutData>
        </HBox>
        <html:div class="exampleDiv"/>
    </l:Grid>

    <!-- Agenda filter -->
    <l:Grid
        containerQuery="false"
        defaultSpan="XL2 L2 M12 S12"
        hSpacing="1">
        <html:div class="exampleDiv"/>
        <HBox alignItems="Center" justifyContent="Start">
            <FlexBox direction="Column" alignItems="Start" class="sapUiTinyMarginEnd">
                <Label text="Channels" />
                <ComboBox
                    selectedKey="all"
                    selectionChange="changeAgendaTracks">
                    <core:Item key="track1" text="Channel 1 ({i18n>agendaTableHeaderTrack1})" />
                    <core:Item key="track2" text="Channel 2 ({i18n>agendaTableHeaderTrack2})" />
                    <core:Item key="track3" text="Channel 3 ({i18n>agendaTableHeaderTrack3})" />
                    <core:Item key="all" text="{i18n>agendaFilterAll}" />
                </ComboBox>
            </FlexBox>
            
            <FlexBox direction="Column" alignItems="Start">
                <Label text="{i18n>agendaFilterLanguage}" />
                <ComboBox
                    selectedKey="all"
                    selectionChange="changeAgendaLanguage">
                    <core:Item key="de" text="{i18n>agendaFilterLanguageDE}" />
                    <core:Item key="en" text="{i18n>agendaFilterLanguageEN}" />
                    <core:Item key="all" text="{i18n>agendaFilterAll}" />
                </ComboBox>
            </FlexBox>

            <layoutData>
                <l:GridData span="XL8 L8 M12 S12"/>
            </layoutData>
        </HBox>
        <html:div class="exampleDiv"/>
    </l:Grid>
            
